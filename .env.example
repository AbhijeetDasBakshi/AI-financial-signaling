NEWSDATA_API_KEY=
MONGO_DB=financial_signals
MONGO_URI=mongodb://localhost:27017
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/financial_signals

# set false to skip backtest on /analyze (faster)
BACKTEST_ON_ANALYZE=true   
BACKTEST_PERIOD=6mo

# ── LLM Provider — switch anytime to openrouter──
LLM_PROVIDER=groq          

# OpenRouter (recommended — 50+ free models)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Groq (alternative)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Shared settings
LLM_MAX_TOKENS=400
LLM_TEMPERATURE=0.3